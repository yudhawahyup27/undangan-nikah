# Wedding Invitation - Environment Variables
# Salin file ini jadi `.env` (jangan commit .env ke Git)

# App
NUXT_PUBLIC_SITE_URL=https://nikah.ywp.my.id
NUXT_PUBLIC_WEDDING_DATE=2026-11-29
NUXT_PUBLIC_BRIDE_NAME=Nur Kotimah
NUXT_PUBLIC_GROOM_NAME=Yudha Wahyu Pratama

# Firebase Firestore (ucapan & RSVP)
# Ambil dari Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_PRIVATE_KEY_DISINI\n-----END PRIVATE KEY-----\n"
